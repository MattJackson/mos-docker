# Phase 0 — Vanilla VNC sanity check.
# Adds: phase 0 launcher (empty disk + UEFI shell).
# Stack: alpine + OEM QEMU 10.2.2 + OVMF + empty raw disk.
# Pass: UEFI shell visible via noVNC at port 6080.

FROM mos-docker-base:latest

COPY launch_phase0.sh /opt/macos/launch_phase0.sh
RUN chmod +x /opt/macos/launch_phase0.sh

ENV NOVNC_PORT=6080 VNC_PORT=5900
EXPOSE 6080

CMD ["/opt/macos/launch_phase0.sh"]
