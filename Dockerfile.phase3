# Phase 3 — Add Apple SMC OSK + apple-kbd / apple-tablet USB identity.
# Inherits phase2 (patched QEMU + OpenCore + macOS image). Adds: only the
# phase 3 launcher — same image binaries, different QEMU args.
# Pass: macOS login screen via vmware-vga path, noVNC at port 6083.

FROM mos-docker-phase2:latest

COPY launch_phase3.sh /opt/macos/launch_phase3.sh
RUN chmod +x /opt/macos/launch_phase3.sh

ENV NOVNC_PORT=6083 VNC_PORT=5903
EXPOSE 6083

CMD ["/opt/macos/launch_phase3.sh"]
