# Removable screenshot capture sidecar.
# Production builds do NOT include this. Loaded at test-time only via
# `docker compose -f compose.phaseN.yml -f compose.screenshot.yml up -d`.
#
# Captures the noVNC viewport using headless Chromium + xvfb, writes
# /data/run/phase-${PHASE}-current.png on a configurable BOOT_WAIT_SECS
# delay. The screenshot is then synced to the laptop via
# scripts/capture-screenshot.sh.

FROM alpine:3.20

RUN apk add --no-cache \
    chromium \
    xvfb \
    py3-pillow \
    bash \
    curl

COPY scripts/screenshot-sidecar.sh /usr/local/bin/screenshot-sidecar.sh
RUN chmod +x /usr/local/bin/screenshot-sidecar.sh

ENV PHASE=0 \
    NOVNC_URL=http://127.0.0.1:6080/vnc.html?autoconnect=1 \
    OUTPUT_PATH=/data/run/phase-0-current.png \
    BOOT_WAIT_SECS=75

CMD ["/usr/local/bin/screenshot-sidecar.sh"]
