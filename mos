#!/bin/bash
# mos — convenience CLI wrapper for mos-docker.
#
# Usage:
#   ./mos install       — install macOS into ./data/disk.img (interactive, ~30 min)
#   ./mos run           — run installed macOS (daemon)
#   ./mos test <phase>  — run regression test phase 0..4 (interactive)
#   ./mos build         — build the production image
#   ./mos build-test    — build the test image (extends production)
#   ./mos logs          — tail the running container's log
#   ./mos stop          — stop running containers
#   ./mos shell         — exec a shell into the running container
#
# This is a thin wrapper over `docker compose`. You can use `docker compose`
# directly if you prefer.
set -euo pipefail
cd "$(dirname "$0")"

mkdir -p data baselines

# kill_prev_phase <phase>
# Remove any leftover same-phase test container (stopped, running, or zombie)
# before starting a new one. Each phase pins per-phase sockets
# (qemu-phase<N>-*.sock) and noVNC port 608<N>; a leftover same-phase
# container silently hogs them and the new QEMU exits without producing
# serial output. Different-phase containers are left alone so phases can run
# in parallel.
#
# Names are anchored prefix `mos-test-phase<N>-` followed by a unique
# suffix (HHMMSS+PID), so this filter picks up every same-phase container
# without ambiguity and without matching different-phase containers. With
# `init: true` in compose.test.yml, abnormal QEMU exits no longer leave
# dockerd/containerd state desynced, so each `docker rm -f` reliably
# terminates without hanging.
kill_prev_phase() {
    local cid
    for cid in $(docker ps -aq --filter "name=^mos-test-phase$1-" 2>/dev/null); do
        docker rm -f "$cid" >/dev/null 2>&1 || true
    done
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    build)
        # The heavy QEMU + libapplegfx compile lives in mos-qemu's CI:
        #   ghcr.io/mattjackson/mos-qemu-patched:<tag>
        #   ghcr.io/mattjackson/mos-qemu-oem:<version>
        # This repo's Dockerfile COPY-froms those images, so `./mos build`
        # is just runtime apk + scripts + OpenCore.img — typically ~30s.
        #
        # Default tags: :main (patched) and :11.0.0 (oem). Override via
        # env if you need a specific commit:
        #   MOSQEMU_IMAGE=ghcr.io/.../mos-qemu-patched:<sha> ./mos build
        #   OEM_QEMU_IMAGE=ghcr.io/.../mos-qemu-oem:<ver>   ./mos build
        MOSQEMU_IMAGE="${MOSQEMU_IMAGE:-ghcr.io/mattjackson/mos-qemu-patched:main}"
        OEM_QEMU_IMAGE="${OEM_QEMU_IMAGE:-ghcr.io/mattjackson/mos-qemu-oem:11.0.0}"
        echo "Building mos-docker:latest"
        echo "  patched: $MOSQEMU_IMAGE"
        echo "  oem:     $OEM_QEMU_IMAGE"
        # Pull the artifact images explicitly so a tag advance on GHCR
        # actually reaches us. Without this, docker compose build will
        # happily reuse the cached image content even when the remote
        # tag has moved.
        docker pull "$MOSQEMU_IMAGE" || { echo "ERROR: pull failed for $MOSQEMU_IMAGE" >&2; exit 1; }
        docker pull "$OEM_QEMU_IMAGE" || { echo "ERROR: pull failed for $OEM_QEMU_IMAGE" >&2; exit 1; }
        exec docker compose build \
            --build-arg MOSQEMU_IMAGE="$MOSQEMU_IMAGE" \
            --build-arg OEM_QEMU_IMAGE="$OEM_QEMU_IMAGE" \
            "$@"
        ;;
    build-test)
        # Back-compat alias for `./mos build`. The test/production image
        # split was dropped 2026-05-10 — there's now ONE image
        # (mos-docker:latest) containing both patched + OEM QEMU + test
        # scripts + screenshot tools. Old workflows using `build-test`
        # keep working.
        exec "$0" build "$@"
        ;;
    install)
        exec docker compose run --rm --service-ports install
        ;;
    run)
        exec docker compose up -d "$@"
        ;;
    verify)
        # ./mos verify 80 — Stage 80 regression harness (login wallpaper / progress UI)
        stage="${1:-}"
        case "$stage" in
            80)
                exec ./scripts/verify-stage80.sh "$@"
                ;;
            lockscreen)
                # phase-4 lock-screen gold gate (objective oracle-compare).
                # Scaffolded / gate-off by default; GATE_ON=1 to arm.
                shift
                exec ./scripts/verify-lockscreen.sh "$@"
                ;;
            *)
                echo "usage: $0 verify <stage>  (stage: 80 | lockscreen)" >&2
                exit 2
                ;;
        esac
        ;;
    test)
        # ./mos test <phase|all>
        #   N=0..3: regression check — code-driven serial boot marker +
        #           visual gold-image diff. Returns 0 PASS, 1 FAIL. Inner
        #           supervisor in test.sh is bypassed via
        #           EXTERNAL_SUPERVISOR=1 so the outer test-runner.sh can
        #           take its own gold-diff screendump.
        #   all   : run phases 0..3 sequentially; exit code = number of
        #           failures.
        #   N=4   : interactive M5 dev stack (apple-gfx-pci paravirt). No
        #           auto pass/fail because Stage 20% gate has no gold yet
        #           — operator watches noVNC at port 6084.
        #   N=9   : interactive debug — std-vga + generic HID + writable
        #           disk + no auto-powerdown. For actually logging in,
        #           saving guest settings, enabling Remote Login, etc.
        #           Stays alive until you `./mos stop` or kill the container.
        phase="${1:-}"
        case "$phase" in
            [0-3])
                kill_prev_phase "$phase"
                exec ./scripts/test-runner.sh "$phase"
                ;;
            all)
                exec ./scripts/test-runner.sh all
                ;;
            4)
                kill_prev_phase 4
                # Phase 4: interactive M5 dev. test.sh attaches MacHDD with
                # snapshot=on, so writes go to a per-run RAM overlay;
                # data/disk.img stays read-only. Container exits → overlay
                # vanishes.
                exec docker compose -f compose.test.yml run --rm \
                    --name "mos-test-phase4-$(date +%H%M%S)-$$" test 4
                ;;
            9)
                kill_prev_phase 9
                # Phase 9: interactive debug. Writable disk.img (no
                # snapshot=on), generic HID, std-vga, no supervisor —
                # the VM stays alive indefinitely. Operator stops it
                # manually when done.
                exec docker compose -f compose.test.yml run --rm \
                    --name "mos-test-phase9-$(date +%H%M%S)-$$" test 9
                ;;
            *)
                echo "usage: $0 test <phase|all>  (phase: 0..4 or 9)" >&2
                exit 2
                ;;
        esac
        ;;
    backup-disk)
        # Snapshot the current data/disk.img to /mnt/backup with a timestamped name.
        TS=$(date +%Y%m%d-%H%M%S)
        BACKUP_DIR="${MOS_BACKUP_DIR:-/mnt/backup/mos-docker}"
        DEST="$BACKUP_DIR/disk-${1:-snapshot}-${TS}.img"
        mkdir -p "$BACKUP_DIR"
        echo "Backing up data/disk.img → $DEST"
        cp --sparse=always data/disk.img "$DEST"
        sha256sum "$DEST"
        echo "  ✓ backed up ($(du -h "$DEST" | cut -f1) actual / $(ls -lh "$DEST" | awk '{print $5}') sparse)"
        ;;
    restore-disk)
        BACKUP="${MOS_BACKUP:-/mnt/backup/mos-docker/disk-post-install-20260506.img}"
        if [ ! -f "$BACKUP" ]; then
            echo "ERROR: backup not found at $BACKUP" >&2
            exit 1
        fi
        echo "Restoring data/disk.img from $BACKUP..."
        cp --sparse=always "$BACKUP" data/disk.img
        echo "  ✓ restored ($(du -h data/disk.img | cut -f1) actual / $(ls -lh data/disk.img | awk '{print $5}') sparse)"
        ;;
    logs)
        exec docker compose logs -f "$@"
        ;;
    stop|down)
        exec docker compose down "$@"
        ;;
    shell|exec)
        exec docker compose exec macos bash "$@"
        ;;
    help|--help|-h|"")
        cat <<EOF
mos — mos-docker CLI

Common workflow:
  ./mos build              build the image (one image — production + test merged 2026-05-10)
  ./mos install            install macOS (one-time, interactive — auto-persists)
  ./mos run                start macOS (default: snapshot=on, no disk drift)
  MOS_PERSIST=1 ./mos run  start macOS with writes hitting disk.img
  ./mos logs               watch the container log
  ./mos stop               stop macOS

Regression testing:
   ./mos test 0             sanity (UEFI shell, no macOS)        — gold-diff regression
   ./mos test 1             OEM + bare-min stack (login screen)  — gold-diff regression  [TRANSIENT]
   ./mos test 2             patched + bare-min (binary swap)     — gold-diff regression
   ./mos test 3             + apple-magic-keyboard / apple-mighty-mouse (Apple HID) — gold-diff regression
   ./mos test 4             apple-gfx-pci paravirt (M5 dev stack) — INTERACTIVE, no auto pass/fail
                                                                    (Stage 20% gate; no gold yet)
   ./mos test all           run phases 0..3 in sequence; exit code = number of failures

Stage regression:
   ./mos verify 80          Stage 80 — login wallpaper / progress UI stable boot

For phases 0..3, "test" = launch container + watch serial for the boot
marker (loginwindow for 1..3, OVMF marker for 0) + take a screendump +
gold-diff against baselines/phase-N-gold.png. PASS only if BOTH the
serial marker is hit AND the screendump matches gold within fuzz
tolerance. Tears down the container automatically.

Phase 1 is [TRANSIENT] — drops when our QEMU patches land upstream.
End state (post-upstream): 0 sanity, 1 patched-baseline, 2 +apple-kbd,
3 apple-gfx-pci product.

Bare-min stack (Phases 1+): std-vga + isa-applesmc + ICH9 globals + macOS HD
+ OpenCore. isa-applesmc + ICH9 are required; without them macOS hangs in
AppleACPICPU busy timeouts.

Each test phase >= 1 restores data/disk.img from MOS_BACKUP before
running. Default backup: /mnt/backup/mos-docker/disk-post-install-20260506.img.
Override with MOS_BACKUP=path. Skip restore with MOS_TEST_NO_RESTORE=1.

Disk snapshots:
  ./mos backup-disk [tag]  cp data/disk.img → /mnt/backup/mos-docker/disk-<tag>-<ts>.img
  ./mos restore-disk       cp $MOS_BACKUP → data/disk.img

Connect to the VM (install + test phases use bundled noVNC on these ports):
  install:  http://localhost:6080/vnc.html?autoconnect=1
  test 0:   http://localhost:6080/vnc.html?autoconnect=1
  test 1:   http://localhost:6081/vnc.html?autoconnect=1
  test 2:   http://localhost:6082/vnc.html?autoconnect=1
  test 3:   http://localhost:6083/vnc.html?autoconnect=1
  test 4:   http://localhost:6084/vnc.html?autoconnect=1

Production:  use your existing noVNC service (compose.yml does not bundle one).

Persistent state: ./data/{disk.img,OpenCore.img,recovery.img,logs/,run/}
EOF
        ;;
    *)
        echo "unknown command: $cmd" >&2
        echo "run '$0 help' for usage" >&2
        exit 2
        ;;
esac
