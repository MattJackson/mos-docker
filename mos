#!/bin/bash
# mos — convenience CLI wrapper for mos-docker.
#
# Usage:
#   ./mos install       — install macOS into ./data/disk.img (interactive, ~30 min)
#   ./mos run           — run installed macOS (daemon)
#   ./mos test <phase>  — run regression test phase 0..4 (interactive)
#   ./mos build         — build the production image
#   ./mos build-test    — build the test image (extends production)
#   ./mos logs          — tail the running container's log
#   ./mos stop          — stop running containers
#   ./mos shell         — exec a shell into the running container
#
# This is a thin wrapper over `docker compose`. You can use `docker compose`
# directly if you prefer.
set -euo pipefail
cd "$(dirname "$0")"

mkdir -p data baselines

cmd="${1:-help}"
shift || true

case "$cmd" in
    build)
        exec docker compose build "$@"
        ;;
    build-test)
        exec docker compose -f compose.yml -f compose.test.yml build test
        ;;
    install)
        exec docker compose run --rm --service-ports install
        ;;
    run)
        exec docker compose up -d "$@"
        ;;
    test)
        phase="${1:-}"
        if [[ ! "$phase" =~ ^[0-4]$ ]]; then
            echo "usage: $0 test <phase>  (phase: 0..4)" >&2
            exit 2
        fi
        # No pre-test disk restore needed — scripts/test.sh attaches the
        # MacHDD drive with snapshot=on, so every test write goes to a
        # per-run overlay in QEMU's tmp and the underlying data/disk.img
        # stays read-only. Container exits → overlay vanishes.
        # Use ./mos restore-disk for ad-hoc manual restores if disk.img
        # itself ever drifts (it shouldn't, given snapshot=on).
        exec docker compose -f compose.test.yml run --rm test "$phase"
        ;;
    backup-disk)
        # Snapshot the current data/disk.img to /mnt/backup with a timestamped name.
        TS=$(date +%Y%m%d-%H%M%S)
        BACKUP_DIR="${MOS_BACKUP_DIR:-/mnt/backup/mos-docker}"
        DEST="$BACKUP_DIR/disk-${1:-snapshot}-${TS}.img"
        mkdir -p "$BACKUP_DIR"
        echo "Backing up data/disk.img → $DEST"
        cp --sparse=always data/disk.img "$DEST"
        sha256sum "$DEST"
        echo "  ✓ backed up ($(du -h "$DEST" | cut -f1) actual / $(ls -lh "$DEST" | awk '{print $5}') sparse)"
        ;;
    restore-disk)
        BACKUP="${MOS_BACKUP:-/mnt/backup/mos-docker/disk-post-install-20260506.img}"
        if [ ! -f "$BACKUP" ]; then
            echo "ERROR: backup not found at $BACKUP" >&2
            exit 1
        fi
        echo "Restoring data/disk.img from $BACKUP..."
        cp --sparse=always "$BACKUP" data/disk.img
        echo "  ✓ restored ($(du -h data/disk.img | cut -f1) actual / $(ls -lh data/disk.img | awk '{print $5}') sparse)"
        ;;
    logs)
        exec docker compose logs -f "$@"
        ;;
    stop|down)
        exec docker compose down "$@"
        ;;
    shell|exec)
        exec docker compose exec macos bash "$@"
        ;;
    help|--help|-h|"")
        cat <<EOF
mos — mos-docker CLI

Common workflow:
  ./mos build              build the production image
  ./mos install            install macOS (one-time, interactive via noVNC)
  ./mos run                start macOS in the background
  ./mos logs               watch the container log
  ./mos stop               stop macOS

Regression testing:
  ./mos build-test         build the test image
  ./mos test 0             vanilla VNC (UEFI shell, no disk)
  ./mos test 1             OEM QEMU + macOS disk (panics in pmap on Sequoia)
  ./mos test 2             patched QEMU + macOS disk (boots clean)
  ./mos test 3             + Apple identity QEMU args
  ./mos test 4             + apple-gfx-pci (M5 gate; black screen until opcodes)

Each test phase >= 1 restores data/disk.img from MOS_BACKUP before
running. Default backup: /mnt/backup/mos-docker/disk-post-install-20260506.img.
Override with MOS_BACKUP=path. Skip restore with MOS_TEST_NO_RESTORE=1.

Disk snapshots:
  ./mos backup-disk [tag]  cp data/disk.img → /mnt/backup/mos-docker/disk-<tag>-<ts>.img
  ./mos restore-disk       cp $MOS_BACKUP → data/disk.img

Connect to the VM (install + test phases use bundled noVNC on these ports):
  install:  http://localhost:6080/vnc.html?autoconnect=1
  test 0:   http://localhost:6080/vnc.html?autoconnect=1
  test 1:   http://localhost:6081/vnc.html?autoconnect=1
  test 2:   http://localhost:6082/vnc.html?autoconnect=1
  test 3:   http://localhost:6083/vnc.html?autoconnect=1
  test 4:   http://localhost:6084/vnc.html?autoconnect=1

Production:  use your existing noVNC service (compose.yml does not bundle one).

Persistent state: ./data/{disk.img,OpenCore.img,recovery.img,logs/,run/}
EOF
        ;;
    *)
        echo "unknown command: $cmd" >&2
        echo "run '$0 help' for usage" >&2
        exit 2
        ;;
esac
