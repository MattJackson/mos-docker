diff --git a/Library/OcAppleKernelLib/PrelinkedKext.c b/Library/OcAppleKernelLib/PrelinkedKext.c
index 01294e6..f28bd61 100644
--- a/Library/OcAppleKernelLib/PrelinkedKext.c
+++ b/Library/OcAppleKernelLib/PrelinkedKext.c
@@ -739,7 +739,66 @@ InternalCachedPrelinkedKext (
   }
 
   if (NewKext == NULL) {
-    return NULL;
+    //
+    // OpenCore15: Search Boot KC fileset entries for the dependency.
+    // On macOS 11+, system kexts like IOGraphicsFamily are embedded in the
+    // Boot Kernel Collection as fileset entries. The prelinked kext list and
+    // XML plist don't include them, but their Mach-O binaries and symbols
+    // are present in the KC at the fileset entry's FileOffset.
+    //
+    if (Prelinked->IsKernelCollection) {
+      MACH_LOAD_COMMAND             *Command;
+      MACH_FILESET_ENTRY_COMMAND    *FsEntry;
+      CONST CHAR8                   *EntryName;
+
+      Command = NULL;
+      while ((Command = MachoGetNextCommand (
+                          &Prelinked->PrelinkedMachContext,
+                          MACH_LOAD_COMMAND_FILESET_ENTRY,
+                          Command)) != NULL)
+      {
+        FsEntry   = (MACH_FILESET_ENTRY_COMMAND *)Command;
+        EntryName = (CONST CHAR8 *)((UINTN)FsEntry + FsEntry->EntryId.Offset);
+
+        if (AsciiStrCmp (Identifier, EntryName) == 0) {
+          DEBUG ((DEBUG_INFO, "OCAK: Found dependency %a in KC fileset at offset 0x%Lx\n", Identifier, FsEntry->FileOffset));
+
+          //
+          // Create a minimal PRELINKED_KEXT from the fileset entry.
+          // We only need the Mach-O context for symbol/vtable resolution.
+          //
+          NewKext = AllocateZeroPool (sizeof (*NewKext));
+          if (NewKext != NULL) {
+            NewKext->Signature      = PRELINKED_KEXT_SIGNATURE;
+            NewKext->Identifier     = Identifier;
+            NewKext->BundleLibraries = NULL;
+
+            if (MachoInitializeContext (
+                  &NewKext->Context.MachContext,
+                  Prelinked->Prelinked + (UINTN)FsEntry->FileOffset,
+                  Prelinked->PrelinkedSize - (UINTN)FsEntry->FileOffset,
+                  0,
+                  Prelinked->PrelinkedSize - (UINTN)FsEntry->FileOffset,
+                  Prelinked->Is32Bit))
+            {
+              NewKext->Context.VirtualBase = FsEntry->VirtualAddress;
+              NewKext->Context.VirtualKmod = 0;
+              DEBUG ((DEBUG_INFO, "OCAK: KC fileset kext %a resolved at VA 0x%Lx\n", Identifier, FsEntry->VirtualAddress));
+            } else {
+              DEBUG ((DEBUG_WARN, "OCAK: KC fileset kext %a Mach-O init failed\n", Identifier));
+              FreePool (NewKext);
+              NewKext = NULL;
+            }
+          }
+
+          break;
+        }
+      }
+    }
+
+    if (NewKext == NULL) {
+      return NULL;
+    }
   }
 
   InsertTailList (&Prelinked->PrelinkedKexts, &NewKext->Link);
